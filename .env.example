# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this file (.env.example) is not.

# ---------------------------------------------------------------------------
# Clerk authentication — publishable key only.
# The SECRET key belongs in the backend FastAPI .env, NEVER here.
# Values prefixed with pk_test_... for development, pk_live_... for production.
# Get these from https://dashboard.clerk.com > your app > API Keys
# ---------------------------------------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_b3V0Z29pbmctdG9ydG9pc2UtMzYuY2xlcmsuYWNjb3VudHMuZGV2JA

# ---------------------------------------------------------------------------
# Backend API base URL.
# In dev, Vite proxies /api/* to this host (see vite.config.ts), so both
# http://localhost:8000 (direct) and the Cloudflare Tunnel URL work.
# In production builds, set this to https://api.componentwatch.com
# via the Cloudflare Pages environment variables UI.
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000
